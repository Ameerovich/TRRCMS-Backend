  MatchingCriteria jsonb
  DataComparison jsonb
  Status varchar [not null, default: 'PendingReview', note: 'PendingReview/Resolved/Ignored']
  ResolutionAction int [note: 'ConflictResolutionAction enum']
  DetectedDate timestamp [not null]
  DetectedByUserId uuid
  AssignedDate timestamp
  AssignedToUserId uuid
  ResolvedDate timestamp
  ResolvedByUserId uuid
  ResolutionReason text
  ResolutionNotes text
