  Email varchar
  MobileNumber varchar
  PhoneNumber varchar
  IsContactPerson boolean [not null, default: false]
  HouseholdId uuid [ref: > Households.Id]
  RelationshipToHead int [note: 'RelationshipToHead enum']
  CreatedAtUtc timestamp [not null]
  CreatedBy uuid [not null]
  LastModifiedAtUtc timestamp
  LastModifiedBy uuid
  IsDeleted boolean [not null, default: false]
  DeletedAtUtc timestamp
  DeletedBy uuid
}

Table Households {
  Id uuid [pk]
  RowVersion bytea
  PropertyUnitId uuid [not null, ref: > PropertyUnits.Id]
  HeadOfHouseholdPersonId uuid [ref: > Persons.Id]
  HeadOfHouseholdName varchar
  HouseholdSize int
  OccupancyType int [note: 'OccupancyType enum']
  OccupancyNature int [note: 'OccupancyNature enum']
  MaleCount int
  FemaleCount int
  MaleChildCount int
  FemaleChildCount int
  MaleElderlyCount int
  FemaleElderlyCount int
  MaleDisabledCount int
  FemaleDisabledCount int
  ChildCount int [not null, default: 0, note: 'Computed: MaleChildCount + FemaleChildCount']
  ElderlyCount int [not null, default: 0, note: 'Computed: MaleElderlyCount + FemaleElderlyCount']
  PersonsWithDisabilitiesCount int [not null, default: 0, note: 'Computed: MaleDisabledCount + FemaleDisabledCount']
  Notes text
  CreatedAtUtc timestamp [not null]
  CreatedBy uuid [not null]
  LastModifiedAtUtc timestamp
  LastModifiedBy uuid
  IsDeleted boolean [not null, default: false]
  DeletedAtUtc timestamp
  DeletedBy uuid
}

Table PersonPropertyRelations {
