}

Table SecurityPolicies {
  Id uuid [pk]
  RowVersion bytea
  Version int [unique, not null]
  IsActive boolean [not null, default: false]
  EffectiveFromUtc timestamp [not null]
  EffectiveToUtc timestamp
  // ── Password Policy (owned value object) ──
  Password_MinLength int [not null, default: 8]
  Password_RequireUppercase boolean [not null, default: true]
  Password_RequireLowercase boolean [not null, default: true]
  Password_RequireDigit boolean [not null, default: true]
  Password_RequireSpecialCharacter boolean [not null, default: true]
  Password_ExpiryDays int [not null, default: 90]
  Password_ReuseHistory int [not null, default: 5]
  // ── Session & Lockout Policy (owned value object) ──
  Session_TimeoutMinutes int [not null, default: 30]
  Session_MaxFailedLoginAttempts int [not null, default: 5]
  Session_LockoutDurationMinutes int [not null, default: 15]
  // ── Access Control Policy (owned value object) ──
  Access_AllowPasswordAuth boolean [not null, default: true]
  Access_AllowSsoAuth boolean [not null, default: false]
  Access_AllowTokenAuth boolean [not null, default: true]
  Access_EnforceIpAllowlist boolean [not null, default: false]
  Access_IpAllowlist varchar(2000)
  Access_IpDenylist varchar(2000)
  Access_RestrictByEnvironment boolean [not null, default: false]
  Access_AllowedEnvironments varchar(500)
  // ── Metadata ──
  ChangeDescription varchar(1000)
  AppliedByUserId uuid [not null]
  CreatedAtUtc timestamp [not null]
  CreatedBy uuid [not null]
  LastModifiedAtUtc timestamp
  LastModifiedBy uuid
  IsDeleted boolean [not null, default: false]
  DeletedAtUtc timestamp
  DeletedBy uuid
}

// ═══════════════════════════════════════════════════════
// STAGING (Import Pipeline)
// All staging tables inherit BaseStagingEntity fields:
//   Id, ImportPackageId, OriginalEntityId,
//   StagingValidationStatus, ValidationErrors,
//   ValidationWarnings, IsApprovedForCommit,
//   CommittedEntityId, StagedAtUtc
//   + BaseAuditableEntity audit fields
// ═══════════════════════════════════════════════════════

Table StagingBuildings {
  Id uuid [pk]
  ImportPackageId uuid [not null, ref: > ImportPackages.Id]
  OriginalEntityId uuid
  StagingValidationStatus int [note: 'StagingValidationStatus enum']
  ValidationErrors jsonb
  ValidationWarnings jsonb
  IsApprovedForCommit boolean [not null, default: false]
  CommittedEntityId uuid
  StagedAtUtc timestamp
  BuildingId varchar(17)
  GovernorateCode varchar(2) [not null]
  DistrictCode varchar(2) [not null]
  SubDistrictCode varchar(2) [not null]
  CommunityCode varchar(3) [not null]
  NeighborhoodCode varchar(3) [not null]
  BuildingNumber varchar(5) [not null]
  GovernorateName varchar
  DistrictName varchar
  SubDistrictName varchar
  CommunityName varchar
  NeighborhoodName varchar
  BuildingType int [not null, note: 'BuildingType enum']
  Status int [not null, note: 'BuildingStatus enum']
  NumberOfPropertyUnits int
  NumberOfApartments int
  NumberOfShops int
  BuildingGeometryWkt text [note: 'WKT string, not PostGIS geometry']
  Latitude decimal
  Longitude decimal
  Notes text
  CreatedAtUtc timestamp [not null]
  CreatedBy uuid [not null]
  LastModifiedAtUtc timestamp
  LastModifiedBy uuid
  IsDeleted boolean [not null, default: false]
  DeletedAtUtc timestamp
  DeletedBy uuid
}

Table StagingBuildingDocuments {
  Id uuid [pk]
  ImportPackageId uuid [not null, ref: > ImportPackages.Id]
  OriginalEntityId uuid
  StagingValidationStatus int
  ValidationErrors jsonb
  ValidationWarnings jsonb
  IsApprovedForCommit boolean [not null, default: false]
  CommittedEntityId uuid
  StagedAtUtc timestamp
  OriginalBuildingId uuid [not null, note: 'Refs StagingBuilding by OriginalEntityId']
  Description text
  OriginalFileName varchar [not null]
  FilePath varchar [not null]
  FileSizeBytes bigint [not null]
  MimeType varchar [not null]
  FileHash varchar(64)
  Notes text
  CreatedAtUtc timestamp [not null]
  CreatedBy uuid [not null]
  LastModifiedAtUtc timestamp
  LastModifiedBy uuid
  IsDeleted boolean [not null, default: false]
  DeletedAtUtc timestamp
  DeletedBy uuid
}

Table StagingPropertyUnits {
  Id uuid [pk]
  ImportPackageId uuid [not null, ref: > ImportPackages.Id]
  OriginalEntityId uuid
  StagingValidationStatus int
  ValidationErrors jsonb
  ValidationWarnings jsonb
  IsApprovedForCommit boolean [not null, default: false]
  CommittedEntityId uuid
  StagedAtUtc timestamp
  OriginalBuildingId uuid [not null, note: 'Refs StagingBuilding by OriginalEntityId']
  UnitIdentifier varchar [not null]
  UnitType int [not null, note: 'PropertyUnitType enum']
  Status int [not null, note: 'PropertyUnitStatus enum']
  FloorNumber int
  NumberOfRooms int
  AreaSquareMeters decimal
  Description text
  CreatedAtUtc timestamp [not null]
  CreatedBy uuid [not null]
  LastModifiedAtUtc timestamp
  LastModifiedBy uuid
  IsDeleted boolean [not null, default: false]
  DeletedAtUtc timestamp
  DeletedBy uuid
}

Table StagingPersons {
  Id uuid [pk]
  ImportPackageId uuid [not null, ref: > ImportPackages.Id]
  OriginalEntityId uuid
  StagingValidationStatus int
  ValidationErrors jsonb
  ValidationWarnings jsonb
  IsApprovedForCommit boolean [not null, default: false]
  CommittedEntityId uuid
  StagedAtUtc timestamp
  FamilyNameArabic varchar [not null]
  FirstNameArabic varchar [not null]
  FatherNameArabic varchar [not null]
  MotherNameArabic varchar
  NationalId varchar
  DateOfBirth timestamp
  Email varchar
  MobileNumber varchar
  PhoneNumber varchar
  Gender int [note: 'Gender enum']
  Nationality int [note: 'Nationality enum']
  OriginalHouseholdId uuid [note: 'Refs StagingHousehold by OriginalEntityId']
  RelationshipToHead int [note: 'RelationshipToHead enum']
  IsContactPerson boolean [not null, default: false]
  CreatedAtUtc timestamp [not null]
  CreatedBy uuid [not null]
  LastModifiedAtUtc timestamp
  LastModifiedBy uuid
  IsDeleted boolean [not null, default: false]
  DeletedAtUtc timestamp
  DeletedBy uuid
}

Table StagingHouseholds {
  Id uuid [pk]
  ImportPackageId uuid [not null, ref: > ImportPackages.Id]
  OriginalEntityId uuid
  StagingValidationStatus int
  ValidationErrors jsonb
  ValidationWarnings jsonb
  IsApprovedForCommit boolean [not null, default: false]
  CommittedEntityId uuid
  StagedAtUtc timestamp
  OriginalPropertyUnitId uuid [not null, note: 'Refs StagingPropertyUnit']
  OriginalHeadOfHouseholdPersonId uuid [note: 'Refs StagingPerson']
  HeadOfHouseholdName varchar [not null]
  HouseholdSize int [not null]
  MaleCount int [not null, default: 0]
  FemaleCount int [not null, default: 0]
  MaleChildCount int [not null, default: 0]
  FemaleChildCount int [not null, default: 0]
  MaleElderlyCount int [not null, default: 0]
  FemaleElderlyCount int [not null, default: 0]
  MaleDisabledCount int [not null, default: 0]
  FemaleDisabledCount int [not null, default: 0]
  Notes text
  CreatedAtUtc timestamp [not null]
  CreatedBy uuid [not null]
  LastModifiedAtUtc timestamp
  LastModifiedBy uuid
  IsDeleted boolean [not null, default: false]
  DeletedAtUtc timestamp
  DeletedBy uuid
}

Table StagingPersonPropertyRelations {
  Id uuid [pk]
  ImportPackageId uuid [not null, ref: > ImportPackages.Id]
  OriginalEntityId uuid
  StagingValidationStatus int
  ValidationErrors jsonb
  ValidationWarnings jsonb
  IsApprovedForCommit boolean [not null, default: false]
  CommittedEntityId uuid
  StagedAtUtc timestamp
  OriginalPersonId uuid [not null, note: 'Refs StagingPerson']
  OriginalPropertyUnitId uuid [not null, note: 'Refs StagingPropertyUnit']
  RelationType int [not null, note: 'RelationType enum']
  OwnershipShare decimal
  ContractDetails text
  Notes text
  IsActive boolean [not null, default: true]
  CreatedAtUtc timestamp [not null]
  CreatedBy uuid [not null]
  LastModifiedAtUtc timestamp
  LastModifiedBy uuid
  IsDeleted boolean [not null, default: false]
  DeletedAtUtc timestamp
  DeletedBy uuid
}

Table StagingClaims {
  Id uuid [pk]
  ImportPackageId uuid [not null, ref: > ImportPackages.Id]
  OriginalEntityId uuid
  StagingValidationStatus int
  ValidationErrors jsonb
  ValidationWarnings jsonb
  IsApprovedForCommit boolean [not null, default: false]
  CommittedEntityId uuid
  StagedAtUtc timestamp
  OriginalPropertyUnitId uuid [not null, note: 'Refs StagingPropertyUnit']
  OriginalPrimaryClaimantId uuid [note: 'Refs StagingPerson']
  ClaimNumber varchar
  ClaimType varchar [not null]
  ClaimSource int [not null, note: 'ClaimSource enum']
  CaseStatus int [note: 'CaseStatus enum']
  TenureContractType int [note: 'TenureContractType enum']
  OwnershipShare decimal
  ClaimDescription text
  CreatedAtUtc timestamp [not null]
  CreatedBy uuid [not null]
  LastModifiedAtUtc timestamp
  LastModifiedBy uuid
  IsDeleted boolean [not null, default: false]
  DeletedAtUtc timestamp
  DeletedBy uuid
}

Table StagingEvidences {
  Id uuid [pk]
  ImportPackageId uuid [not null, ref: > ImportPackages.Id]
  OriginalEntityId uuid
  StagingValidationStatus int
  ValidationErrors jsonb
  ValidationWarnings jsonb
  IsApprovedForCommit boolean [not null, default: false]
  CommittedEntityId uuid
  StagedAtUtc timestamp
  OriginalPersonId uuid [note: 'Refs StagingPerson']
  OriginalPersonPropertyRelationId uuid [note: 'Refs StagingPersonPropertyRelation']
  OriginalClaimId uuid [note: 'Refs StagingClaim']
  EvidenceType int [not null, note: 'EvidenceType enum']
  Description text [not null]
  OriginalFileName varchar [not null]
  FilePath varchar [not null]
  FileSizeBytes bigint [not null]
  MimeType varchar [not null]
  FileHash varchar(64)
  IssuingAuthority varchar
  DocumentIssuedDate timestamp
  DocumentExpiryDate timestamp
  DocumentReferenceNumber varchar
  Notes text
  VersionNumber int [not null, default: 1]
  OriginalPreviousVersionId uuid
  IsCurrentVersion boolean [not null, default: true]
  CreatedAtUtc timestamp [not null]
  CreatedBy uuid [not null]
  LastModifiedAtUtc timestamp
  LastModifiedBy uuid
  IsDeleted boolean [not null, default: false]
  DeletedAtUtc timestamp
  DeletedBy uuid
}

Table StagingSurveys {
  Id uuid [pk]
  ImportPackageId uuid [not null, ref: > ImportPackages.Id]
  OriginalEntityId uuid
  StagingValidationStatus int
  ValidationErrors jsonb
  ValidationWarnings jsonb
  IsApprovedForCommit boolean [not null, default: false]
  CommittedEntityId uuid
  StagedAtUtc timestamp
  OriginalBuildingId uuid [not null, note: 'Refs StagingBuilding']
  OriginalPropertyUnitId uuid [note: 'Refs StagingPropertyUnit']
  OriginalFieldCollectorId uuid [note: 'Refs User']
  OriginalClaimId uuid [note: 'Refs StagingClaim']
  OriginalContactPersonId uuid [note: 'Refs StagingPerson']
  ReferenceCode varchar
  Type int [note: 'SurveyType enum']
  Source int [note: 'SurveySource enum']
  SurveyDate timestamp [not null]
  Status int [note: 'SurveyStatus enum']
  GpsCoordinates varchar
  IntervieweeName varchar
  IntervieweeRelationship varchar
  Notes text
  OfficeLocation varchar
  RegistrationNumber varchar
  AppointmentReference varchar
  ContactPhone varchar
  ContactEmail varchar
  CreatedAtUtc timestamp [not null]
  CreatedBy uuid [not null]
  LastModifiedAtUtc timestamp
  LastModifiedBy uuid
  IsDeleted boolean [not null, default: false]
  DeletedAtUtc timestamp
  DeletedBy uuid
}

// ═══════════════════════════════════════════════════════
// TABLE GROUPS
// ═══════════════════════════════════════════════════════

TableGroup CoreProperty {
  Buildings
  BuildingDocuments
  PropertyUnits
}

TableGroup People {
  Persons
  Households
  PersonPropertyRelations
}

TableGroup ClaimsAndEvidence {
  Claims
  Evidences
  EvidenceRelations
  Surveys
}

TableGroup Operations {
  BuildingAssignments
  SyncSessions
  ImportPackages
  ConflictResolutions
}

TableGroup ReferenceData {
  Governorates
  Districts
  SubDistricts
  Communities
  Neighborhoods
  Landmarks
  Streets
}

TableGroup System {
  Users
  UserPermissions
  AuditLogs
  Vocabularies
  SecurityPolicies
}

TableGroup StagingImportPipeline {
  StagingBuildings
  StagingBuildingDocuments
  StagingPropertyUnits
  StagingPersons
  StagingHouseholds
  StagingPersonPropertyRelations
  StagingClaims
  StagingEvidences
  StagingSurveys
}
