Table ImportPackages {
  Id uuid [pk]
  RowVersion bytea
  PackageId uuid [not null, note: 'From .uhc manifest']
  PackageNumber varchar [unique, not null, note: 'PKG-YYYY-NNNN']
  FileName varchar [not null]
  FileSizeBytes bigint [not null]
  PackageCreatedDate timestamp [not null]
  PackageExportedDate timestamp [not null]
