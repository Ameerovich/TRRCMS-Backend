// TRRCMS - Entity Relationship Diagram (DBML)
// PostgreSQL 16 + PostGIS 3.4
// Generated: 2026-03-13
//
// Base Classes (inherited fields present in all tables):
// ─────────────────────────────────────────────────────
// BaseAuditableEntity (all production tables except AuditLogs):
//   Id uuid [pk], RowVersion bytea,
//   CreatedAtUtc timestamp, CreatedBy uuid,
//   LastModifiedAtUtc timestamp, LastModifiedBy uuid,
//   IsDeleted boolean, DeletedAtUtc timestamp, DeletedBy uuid
//
// BaseStagingEntity (all Staging* tables):
//   Id uuid [pk], ImportPackageId uuid [ref: > ImportPackages.Id],
//   OriginalEntityId uuid, StagingValidationStatus int,
//   ValidationErrors jsonb, ValidationWarnings jsonb,
//   IsApprovedForCommit boolean, CommittedEntityId uuid, StagedAtUtc timestamp

// ═══════════════════════════════════════════════════════
// CORE PROPERTY
// ═══════════════════════════════════════════════════════

Table Buildings {
  Id uuid [pk]
  RowVersion bytea
  BuildingId varchar(17) [unique, not null, note: 'Composite code: Gov+Dist+SubDist+Comm+Neigh+BuildingNo']
  GovernorateCode varchar(2) [not null]
  DistrictCode varchar(2) [not null]
  SubDistrictCode varchar(2) [not null]
  CommunityCode varchar(3) [not null]
  NeighborhoodCode varchar(3) [not null]
  BuildingNumber varchar(5) [not null]
  GovernorateName varchar [not null]
  DistrictName varchar [not null]
  SubDistrictName varchar [not null]
  CommunityName varchar [not null]
  NeighborhoodName varchar [not null]
  BuildingType int [not null, note: 'BuildingType enum']
  Status int [not null, note: 'BuildingStatus enum']
  NumberOfPropertyUnits int [not null]
  NumberOfApartments int [not null]
  NumberOfShops int [not null]
  BuildingGeometry geometry [note: 'PostGIS POLYGON/MULTIPOLYGON SRID 4326']
  Latitude decimal
  Longitude decimal
  Notes text
  CreatedAtUtc timestamp [not null]
  CreatedBy uuid [not null]
  LastModifiedAtUtc timestamp
  LastModifiedBy uuid
  IsDeleted boolean [not null, default: false]
  DeletedAtUtc timestamp
  DeletedBy uuid
}

Table BuildingDocuments {
  Id uuid [pk]
  RowVersion bytea
  BuildingId uuid [not null, ref: > Buildings.Id]
  Description text
  OriginalFileName varchar [not null]
  FilePath varchar [not null]
  FileSizeBytes bigint [not null]
  MimeType varchar [not null]
  FileHash varchar(64) [note: 'SHA-256']
  Notes text
  CreatedAtUtc timestamp [not null]
  CreatedBy uuid [not null]
  LastModifiedAtUtc timestamp
  LastModifiedBy uuid
  IsDeleted boolean [not null, default: false]
  DeletedAtUtc timestamp
  DeletedBy uuid
}

Table PropertyUnits {
  Id uuid [pk]
  RowVersion bytea
  BuildingId uuid [not null, ref: > Buildings.Id]
  UnitIdentifier varchar [not null]
  FloorNumber int
  UnitType int [not null, note: 'PropertyUnitType enum']
  Status int [not null, note: 'PropertyUnitStatus enum']
  AreaSquareMeters decimal
  NumberOfRooms int
  Description text
  CreatedAtUtc timestamp [not null]
  CreatedBy uuid [not null]
  LastModifiedAtUtc timestamp
  LastModifiedBy uuid
  IsDeleted boolean [not null, default: false]
  DeletedAtUtc timestamp
  DeletedBy uuid
}

