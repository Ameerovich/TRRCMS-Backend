{
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_DB_HOST;Database=TRRCMS_Prod;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD"
  },
  "JwtSettings": {
    "Secret": "CHANGE-THIS-TO-A-SECURE-RANDOM-KEY-MINIMUM-32-CHARACTERS",
    "Issuer": "TRRCMS.API",
    "Audience": "TRRCMS.Clients",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7,
    "RequireHttpsMetadata": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "TRRCMS": "Information"
    }
  },
  "Cors": {
    "AllowedOrigins": [ "https://your-production-domain.org" ]
  },
  "AllowedHosts": "your-production-domain.org"
}
