# ============================================================
# TRRCMS Environment Configuration
# ============================================================
# 1. Copy this file and rename it to .env
# 2. Fill in the values below
# 3. Place it next to docker-compose.yml on the server
# ============================================================

# PostgreSQL password — used by both the database and the API
DB_PASSWORD=

# JWT secret key — must be at least 32 characters long
JWT_SECRET=
