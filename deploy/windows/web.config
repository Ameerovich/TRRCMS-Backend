<?xml version="1.0" encoding="utf-8"?>
<!--
  Reference web.config for hosting TRRCMS.WebAPI under IIS via the ASP.NET Core
  Module v2. `dotnet publish` generates a web.config automatically; copy the
  TRRCMS-specific settings below into the generated file (or use this one) AFTER
  publish. Three things matter here:

    1. hostingModel="outofprocess"
       The app configures its 500 MB upload limit on KESTREL
       (Program.cs: ConfigureKestrel → MaxRequestBodySize = 500 MB). That limit
       only takes effect when Kestrel actually handles the request — i.e.
       OUT-OF-PROCESS, where IIS reverse-proxies to Kestrel. With the default
       "inprocess" model the app runs inside IIS's HTTP server, Kestrel is
       bypassed, and the limit falls back to IISServerOptions.MaxRequestBodySize
       (~28.6 MB, never raised in code) — which would reject .uhc imports larger
       than ~28.6 MB. Out-of-process keeps the existing 500 MB code limit valid
       with no code change.

    2. <requestLimits maxAllowedContentLength> — IIS's own request filter caps
       bodies at ~28.6 MB by default and returns HTTP 404.13 for larger uploads,
       BEFORE the request ever reaches Kestrel. 600 MB here = 629145600 bytes,
       comfortably above the app's 500 MB limit (ImportPipeline:MaxUploadSizeMB).

    3. ASPNETCORE_ENVIRONMENT=Production — activates appsettings.Production.json,
       restricted CORS, HTTPS metadata enforcement, and disables Swagger.

  requestTimeout is raised to 20 min so a slow 500 MB upload isn't killed by the
  ANCM default 2-minute timeout (out-of-process only; in-process ignores it).
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <security>
        <requestFiltering>
          <requestLimits maxAllowedContentLength="629145600" />
        </requestFiltering>
      </security>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\TRRCMS.WebAPI.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="outofprocess"
                  requestTimeout="00:20:00">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
